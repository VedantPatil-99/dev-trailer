# Copy to .env.local and fill in values.

# Gemini (required for AI generation)
GEMINI_API_KEY=

# ElevenLabs (required for voiceover)
ELEVENLABS_API_KEY=

# Supabase (optional: enables auth + video storage)
# Create project at https://supabase.com, then create a Storage bucket named "videos" (public).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# or legacy: NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API (optional; app uses in-memory mock when not set)
NEXT_PUBLIC_API_URL=http://localhost:5001/api
NEXT_PUBLIC_USE_MOCK_API=true
